# ------------------------
# Advanced Tips
# ------------------------
# Functional inheritance / closure-based OOP
fn createDrone(name) {
    global battery = 100
    return {
        name = name,
        fly = () => {
            global battery = battery - 10
            print(name + " flying! Battery:", battery)
        }
    }
}
let drone1 = createDrone("Eagle")
drone1.fly()
