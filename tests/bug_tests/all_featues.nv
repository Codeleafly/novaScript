# NPM Modules
# ------------------------
import { chalk } from "npm:chalk@5.2.0"
import { axios } from "npm:axios"

Console.error(chalk.red("NPM chalk test"))
async fn fetchGitHub() {
    let res = await axios.get("https://api.github.com")
    print("GitHub status:", res.status)
}
fetchGitHub()

