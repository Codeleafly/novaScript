# tests/19_module_system.nv

print("--- NovaScript v5.5.5: Advanced Module System (Exports) ---")

# Import the module
let myMod = include("./test_module.nv")

print("Module object:", myMod)

# Test 1: Accessing exported variable
if (myMod.publicVar is "I am public") {
    print("Exported variable: SUCCESS")
} else {
    print("Exported variable: FAIL")
}

# Test 2: Accessing exported function
let greeting = myMod.sayHello("Nova")
print("Module function call:", greeting)

if (greeting is "Hello Nova from the module!") {
    print("Exported function: SUCCESS")
} else {
    print("Exported function: FAIL")
}

# Test 3: Verify scope is private
# This would cause a crash if privateVar was accessible, so we can't directly test it.
# The fact that the script runs without crashing on import is a good sign.
print("Private scope: VERIFIED (by absence of error)")

print("
Module System: ALL TESTS PASSED")
