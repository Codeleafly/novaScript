# tests/21_array_methods.nv
print("--- Advanced Array Methods (v5.5.0) ---")

let arr = [1, 2, 3]
print("Original Array:", arr)

# Push
Array.push(arr, 4)
Array.push(arr, 5)
print("After push(4, 5):", arr)

# Pop
let last = Array.pop(arr)
print("Popped item:", last)
print("After pop:", arr)

# Join
let joined = Array.join(arr, " - ")
print("Joined:", joined)

# Slice
let subarray = Array.slice(arr, 1, 3)
print("Slice (1 to 3):", subarray)

# Reverse
let rev = Array.reverse(arr)
print("Reversed:", rev)
# Original should be untouched because reverse creates a copy in our implementation
print("Original unchanged:", arr)

# Includes / IndexOf
if (Array.includes(arr, 2) and Array.indexOf(arr, 2) is 1) {
    print("Includes & IndexOf: SUCCESS")
}

if (last is 5 and subarray[0] is 2 and rev[0] is 4) {
    print("Array Methods: ALL PASSED")
}
