# tests/04_functions.nv

print("--- Function & Recursion Tests ---")

# Simple function
fn greet(name) {
    print("Hello", name)
}
greet("Developer")

# Function with return
fn add(a, b) {
    return a + b
}
let sum = add(10, 20)
print("Sum 10 + 20 =", sum)

# Recursion: Factorial
fn factorial(n) {
    if (n is 0) {
        return 1
    }
    return n * factorial(n - 1)
}
let fact5 = factorial(5)
print("factorial(5) =", fact5)

# Recursion: Fibonacci
fn fib(n) {
  if (n < 2) {
    return n
  }
  return fib(n - 1) + fib(n - 2)
}
let fib7 = fib(7)
print("fibonacci(7) =", fib7)

if (fact5 is 120 and fib7 is 13) {
    print("Functions and recursion: SUCCESS")
}
